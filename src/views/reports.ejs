<%
// Server-side helpers

function verdictChip(verdict, rejectionCategory) {
  const base = 'inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium whitespace-nowrap';
  if (verdict === 'STRONG_MATCH') return `<span class="${base} bg-emerald-50 text-emerald-700">✅ Strong fit</span>`;
  if (verdict === 'WEAK_MATCH')   return `<span class="${base} bg-yellow-50 text-yellow-700">⚠️ Weak fit</span>`;
  if (verdict === 'BLACKLISTED')  return `<span class="${base} bg-gray-100 text-gray-600">🚫 Blacklisted</span>`;
  if (verdict === 'DUPLICATE')    return `<span class="${base} bg-purple-50 text-purple-600">🔁 Duplicate</span>`;
  if (verdict === 'FILTERED')     return `<span class="${base} bg-slate-100 text-slate-500">✂ Filtered</span>`;
  if (verdict === 'NO_MATCH') {
    if (rejectionCategory === 'NO_VISA')           return `<span class="${base} bg-red-50 text-red-600">❌ No visa support</span>`;
    if (rejectionCategory === 'LANGUAGE_MISMATCH') return `<span class="${base} bg-red-50 text-red-600">❌ Language mismatch</span>`;
    if (rejectionCategory === 'PROFILE_MISMATCH')  return `<span class="${base} bg-red-50 text-red-600">❌ Profile mismatch</span>`;
    return `<span class="${base} bg-red-50 text-red-600">❌ No fit</span>`;
  }
  return '';
}

function statusBadge(status) {
  if (status === 'success')       return 'bg-emerald-50 text-emerald-700';
  if (status === 'partial_error') return 'bg-yellow-50 text-yellow-700';
  if (status === 'running')       return 'bg-blue-50 text-blue-700';
  return 'bg-red-50 text-red-600';
}

function statusLabel(status) {
  if (status === 'partial_error') return 'partial error';
  return status;
}

function scoreClass(score) {
  if (score == null) return 'text-gray-400';
  return score >= 71 ? 'text-emerald-600 font-semibold' : score >= 51 ? 'text-yellow-600 font-semibold' : 'text-red-500';
}
%>

<!-- Page header -->
<div class="mb-8">
  <h1 class="text-2xl font-bold text-gray-900">Run Logs</h1>
  <div class="flex items-center justify-between gap-4 mt-1">
    <p class="text-sm text-gray-500">Full audit log of every pipeline run — showing last <%= runs.length %> run<%= runs.length !== 1 ? 's' : '' %> · <a href="/run-diff" class="text-blue-500 hover:underline">Compare</a> last 2 runs</p>
    <label class="flex items-center gap-2 cursor-pointer flex-shrink-0">
      <span class="text-xs text-gray-500">Split by location</span>
      <input type="checkbox" id="location-split-checkbox" onchange="toggleLocationSplit(this.checked)" class="sr-only peer" />
      <div class="relative w-9 h-5 bg-gray-300 peer-checked:bg-blue-500 rounded-full transition-colors after:content-[''] after:absolute after:top-0.5 after:left-0.5 after:bg-white after:rounded-full after:h-4 after:w-4 after:transition-all peer-checked:after:translate-x-4"></div>
    </label>
  </div>
</div>

<% if (runs.length === 0) { %>
<div class="bg-white rounded-xl border border-gray-200 shadow-sm p-12 text-center">
  <svg class="w-10 h-10 text-gray-300 mx-auto mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
  </svg>
  <p class="text-sm text-gray-500">No pipeline runs yet. Run the pipeline from the Dashboard to see results here.</p>
</div>
<% } else { %>

<div class="space-y-3">
<% runs.forEach(run => { %>

<details class="group bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden"
         data-run-id="<%= run.id %>"
         <%= run.preloaded ? 'data-preloaded' : '' %>>

  <summary class="flex items-center justify-between px-5 py-4 cursor-pointer select-none list-none hover:bg-gray-50 transition-colors">
    <div class="flex items-center gap-3 flex-wrap min-w-0">
      <!-- Expand/collapse chevron -->
      <svg class="w-4 h-4 text-gray-400 flex-shrink-0 transition-transform group-open:rotate-90" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
      </svg>

      <!-- Date & time -->
      <div class="flex items-center gap-2">
        <span class="font-semibold text-gray-900 text-sm"><%= run.ran_at_date %></span>
        <span class="text-gray-400 text-xs">·</span>
        <span class="text-gray-500 text-sm"><%= run.ran_at_time %></span>
      </div>

      <!-- Status badge -->
      <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium capitalize <%= statusBadge(run.status) %>">
        <%= statusLabel(run.status) %>
      </span>

      <!-- Trigger badge -->
      <% if (run.trigger === 'manual') { %>
      <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-blue-50 text-blue-600">manual</span>
      <% } %>
    </div>

    <!-- Stats summary + cost button -->
    <div class="flex items-center gap-3 flex-shrink-0 ml-4">
      <span class="text-xs text-gray-500 hidden sm:block">
        <span class="font-medium text-gray-700"><%= run.jobs_fetched %></span> fetched
        · <span class="font-medium text-emerald-600"><%= run.jobs_strong_match %></span> strong
        · <span class="font-medium text-yellow-600"><%= run.jobs_weak_match %></span> weak
        · <span class="font-medium text-red-500"><%= run.jobs_no_match %></span> no match
        · <span class="font-medium text-purple-600"><%= run.jobs_duplicate %></span> duplicates
        <% if (run.filtered_count > 0) { %>· <span class="font-medium text-slate-500"><%= run.filtered_count %></span> filtered<% } %>
        <% if (run.blacklisted_count > 0) { %>· <span class="font-medium text-gray-500"><%= run.blacklisted_count %></span> blacklisted<% } %>
      </span>

      <!-- Cost button -->
      <% if (run.cost_openai_usd != null || run.cost_apify_usd != null) { %>
      <div class="relative" onclick="event.stopPropagation()">
        <button
          onclick="toggleCostPopup('<%= run.id %>')"
          class="text-sm font-bold text-emerald-600 hover:text-emerald-700 w-7 h-7 flex items-center justify-center rounded-lg hover:bg-emerald-50 transition-colors"
          title="Run costs"
        >$</button>
        <div id="cost-popup-<%= run.id %>" class="hidden fixed z-50 bg-white border border-gray-200 rounded-xl shadow-lg p-3 text-xs min-w-[170px]">
          <% if (run.scraping_provider) { %>
          <div class="flex justify-between gap-6 text-gray-500 pb-1.5 mb-1.5 border-b border-gray-100">
            <span>Provider</span>
            <span class="font-medium text-gray-700"><%= run.scraping_provider === 'harvestapi' ? 'HarvestAPI' : run.scraping_provider.charAt(0).toUpperCase() + run.scraping_provider.slice(1) %></span>
          </div>
          <% } %>
          <% const totalCost = (run.cost_openai_usd ?? 0) + (run.cost_apify_usd ?? 0); %>
          <div class="flex justify-between gap-6 pb-1.5 mb-1.5 border-b border-gray-100">
            <span class="font-medium text-gray-700">Total</span>
            <span class="font-bold text-gray-900">$<%= totalCost.toFixed(4) %></span>
          </div>
          <% if (run.cost_apify_usd != null) { %>
          <div class="flex justify-between gap-6 text-gray-600">
            <span>Fetch</span>
            <span class="font-medium text-gray-900">$<%= run.cost_apify_usd.toFixed(4) %></span>
          </div>
          <% } %>
          <% if (run.cost_openai_usd != null) { %>
          <div class="flex justify-between gap-6 text-gray-600 mt-1.5">
            <span>AI</span>
            <span class="font-medium text-gray-900">$<%= run.cost_openai_usd.toFixed(4) %></span>
          </div>
          <% } %>
        </div>
      </div>
      <% } %>
    </div>
  </summary>

  <!-- Expanded content -->
  <div class="border-t border-gray-100">

    <% if (run.error_log) { %>
    <div class="px-5 py-3 bg-red-50 border-b border-red-100">
      <p class="text-xs text-red-600 font-medium">Error log:</p>
      <pre class="text-xs text-red-500 mt-1 whitespace-pre-wrap"><%= run.error_log %></pre>
    </div>
    <% } %>

    <!-- Jobs container: server-rendered for preloaded runs, lazy for the rest -->
    <div class="run-jobs-container">
      <% if (run.preloaded) { %>
        <% if (run.jobs.length === 0) { %>
        <div class="px-5 py-8 text-center text-sm text-gray-400">
          No job logs for this run.
          <% if (run.status === 'running') { %><span class="block mt-1 text-xs">Run is still in progress.</span><% } %>
        </div>
        <% } else { %>

        <!-- Desktop table -->
        <table class="hidden md:table w-full">
          <tbody class="divide-y divide-gray-50">
            <% run.jobs.forEach(function(job, idx) { %>
            <tr data-row-idx="<%= idx %>" data-country="<%= job.country %>" class="hover:bg-gray-50 transition-colors">
              <td class="px-5 py-2.5 text-xs text-gray-400 whitespace-nowrap w-0">
                <span class="block"><%= job.logged_date %></span>
                <span class="block text-gray-300"><%= job.logged_time %></span>
              </td>
              <td class="px-3 py-2.5 text-sm text-gray-600 whitespace-nowrap w-0 max-w-[160px] truncate"><%= job.company %></td>
              <td class="px-3 py-2.5 text-sm text-gray-900">
                <% if (job.internal_job_id) { %>
                  <a href="/job/<%= job.internal_job_id %>" class="hover:text-blue-600 transition-colors"><%= job.title %></a>
                <% } else { %>
                  <%= job.title %>
                <% } %>
                <% if (job.location) { %><span class="block text-xs text-gray-400 truncate"><%= job.location %></span><% } %>
              </td>
              <td class="pl-3 py-2.5 w-0 whitespace-nowrap text-right">
                <span onclick="showJobMenu(event,this)"
                      data-internal-id="<%= job.internal_job_id || '' %>"
                      data-url="<%= job.url || '' %>"
                      data-log-id="<%= job.id %>"
                      data-verdict="<%= job.ai_verdict %>"
                      class="cursor-pointer">
                  <%- verdictChip(job.ai_verdict, job.rejection_category) %>
                </span>
              </td>
              <td class="py-2.5 px-1 w-0 whitespace-nowrap text-right" style="min-width:2.25rem;">
                <% if (job.ai_score != null) { %><span class="text-xs <%= scoreClass(job.ai_score) %>"><%= job.ai_score %></span><% } %>
              </td>
              <td class="pl-2 pr-5 py-2.5 w-0 whitespace-nowrap">
                <% if (job.url) { %>
                  <a href="<%= job.url %>" target="_blank" rel="noopener noreferrer" class="text-blue-500 hover:underline text-xs">link</a>
                <% } else { %>
                  <span class="text-gray-300 text-xs">—</span>
                <% } %>
              </td>
            </tr>
            <% }); %>
          </tbody>
        </table>

        <!-- Mobile list -->
        <div class="md:hidden jobs-mobile-list divide-y divide-gray-50">
          <% run.jobs.forEach(function(job, idx) { %>
          <% const target = job.internal_job_id ? '/job/' + job.internal_job_id : (job.url || null); %>
          <div class="job-mobile-row px-4 py-3 hover:bg-gray-50 transition-colors<%= target ? ' cursor-pointer' : '' %>"
               data-row-idx="<%= idx %>"
               data-country="<%= job.country %>"
               <% if (target) { %>data-href="<%= target %>" onclick="location.href=this.dataset.href"<% } %>>
            <div class="flex items-center justify-between gap-2 mb-0.5">
              <span class="text-sm font-medium text-gray-700 truncate"><%= job.company %></span>
              <div class="flex items-center gap-1.5 flex-shrink-0">
                <span onclick="showJobMenu(event,this)"
                      data-internal-id="<%= job.internal_job_id || '' %>"
                      data-url="<%= job.url || '' %>"
                      data-log-id="<%= job.id %>"
                      data-verdict="<%= job.ai_verdict %>"
                      class="cursor-pointer">
                  <%- verdictChip(job.ai_verdict, job.rejection_category) %>
                </span>
                <% if (job.ai_score != null) { %><span class="text-xs <%= scoreClass(job.ai_score) %>" style="min-width:1.75rem;display:inline-block;text-align:right;"><%= job.ai_score %></span><% } %>
              </div>
            </div>
            <p class="text-xs text-gray-500 truncate"><%= job.title %></p>
            <% if (job.location) { %><p class="text-xs text-gray-400 truncate mt-0.5"><%= job.location %></p><% } %>
            <p class="text-xs text-gray-300 mt-0.5"><%= job.logged_date %> · <%= job.logged_time %></p>
          </div>
          <% }); %>
        </div>

        <% } %>
      <% } %>
      <!-- Lazy runs: container is empty; JS fills it on first expand -->
    </div>

    <!-- Run footer -->
    <div class="px-5 py-2.5 border-t border-gray-100 text-xs text-gray-400 flex items-center justify-between">
      <span>Run #<%= run.id %></span>
      <% if (run.duration_ms) { %>
      <span><%= (run.duration_ms / 1000).toFixed(1) %>s</span>
      <% } %>
    </div>

  </div>
</details>

<% }); %>
</div>
<% } %>

<!-- Job context menu (shared) -->
<div id="job-menu" class="hidden fixed z-50 bg-white border border-gray-200 rounded-xl shadow-lg p-1.5 text-xs min-w-[160px]">
  <a id="job-menu-view" href="#" class="flex items-center gap-2 px-3 py-2 rounded-lg hover:bg-gray-50 text-gray-700 transition-colors">View details</a>
  <a id="job-menu-link" href="#" target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 px-3 py-2 rounded-lg hover:bg-gray-50 text-gray-700 transition-colors">Open on LinkedIn</a>
  <div id="job-menu-verdict-section" class="mt-1 pt-1 border-t border-gray-100">
    <p class="px-3 py-1 text-xs font-medium text-gray-400">Change verdict</p>
    <button onclick="menuSetVerdict('STRONG_MATCH')" class="flex items-center gap-2 px-3 py-2 rounded-lg hover:bg-emerald-50 text-emerald-700 w-full text-left transition-colors">✅ Strong fit</button>
    <button onclick="menuSetVerdict('WEAK_MATCH')"   class="flex items-center gap-2 px-3 py-2 rounded-lg hover:bg-yellow-50 text-yellow-700 w-full text-left transition-colors">⚠️ Weak fit</button>
    <button onclick="menuSetVerdict('NO_MATCH')"     class="flex items-center gap-2 px-3 py-2 rounded-lg hover:bg-red-50 text-red-600 w-full text-left transition-colors">❌ No fit</button>
  </div>
</div>

<script>
// ---- Utilities ----

function escHtml(str) {
  return String(str || '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;').replace(/'/g,'&#39;');
}

function scoreClass(score) {
  if (score == null) return 'text-gray-400';
  return score >= 71 ? 'text-emerald-600 font-semibold' : score >= 51 ? 'text-yellow-600 font-semibold' : 'text-red-500';
}

function logVerdictChip(verdict, rejectionCategory) {
  const base = 'inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium whitespace-nowrap';
  if (verdict === 'STRONG_MATCH') return '<span class="' + base + ' bg-emerald-50 text-emerald-700">\u2705 Strong fit</span>';
  if (verdict === 'WEAK_MATCH')   return '<span class="' + base + ' bg-yellow-50 text-yellow-700">\u26a0\ufe0f Weak fit</span>';
  if (verdict === 'BLACKLISTED')  return '<span class="' + base + ' bg-gray-100 text-gray-600">\uD83D\uDEAB Blacklisted</span>';
  if (verdict === 'DUPLICATE')    return '<span class="' + base + ' bg-purple-50 text-purple-600">\uD83D\uDD01 Duplicate</span>';
  if (verdict === 'FILTERED')     return '<span class="' + base + ' bg-slate-100 text-slate-500">\u2702 Filtered</span>';
  if (verdict === 'NO_MATCH') {
    if (rejectionCategory === 'NO_VISA')           return '<span class="' + base + ' bg-red-50 text-red-600">\u274c No visa support</span>';
    if (rejectionCategory === 'LANGUAGE_MISMATCH') return '<span class="' + base + ' bg-red-50 text-red-600">\u274c Language mismatch</span>';
    if (rejectionCategory === 'PROFILE_MISMATCH')  return '<span class="' + base + ' bg-red-50 text-red-600">\u274c Profile mismatch</span>';
    return '<span class="' + base + ' bg-red-50 text-red-600">\u274c No fit</span>';
  }
  return '';
}

// ---- Build jobs HTML from JSON (used by lazy-load) ----

function buildJobsHTML(jobs) {
  if (!jobs || jobs.length === 0) {
    return '<div class="px-5 py-8 text-center text-sm text-gray-400">No job logs for this run.</div>';
  }

  let tableRows = '';
  let mobileRows = '';

  jobs.forEach(function(job, idx) {
    const sc = scoreClass(job.ai_score);
    const target = job.internal_job_id ? '/job/' + job.internal_job_id : (job.url || null);

    tableRows += '<tr data-row-idx="' + idx + '" data-country="' + escHtml(job.country) + '" class="hover:bg-gray-50 transition-colors">'
      + '<td class="px-5 py-2.5 text-xs text-gray-400 whitespace-nowrap w-0">'
      + '<span class="block">' + escHtml(job.logged_date) + '</span>'
      + '<span class="block text-gray-300">' + escHtml(job.logged_time) + '</span>'
      + '</td>'
      + '<td class="px-3 py-2.5 text-sm text-gray-600 whitespace-nowrap w-0 max-w-[160px] truncate">' + escHtml(job.company) + '</td>'
      + '<td class="px-3 py-2.5 text-sm text-gray-900">'
      + (job.internal_job_id
          ? '<a href="/job/' + job.internal_job_id + '" class="hover:text-blue-600 transition-colors">' + escHtml(job.title) + '</a>'
          : escHtml(job.title))
      + (job.location ? '<span class="block text-xs text-gray-400 truncate">' + escHtml(job.location) + '</span>' : '')
      + '</td>'
      + '<td class="pl-3 py-2.5 w-0 whitespace-nowrap text-right">'
      + '<span onclick="showJobMenu(event,this)"'
      + ' data-internal-id="' + (job.internal_job_id || '') + '"'
      + ' data-url="' + escHtml(job.url || '') + '"'
      + ' data-log-id="' + job.id + '"'
      + ' data-verdict="' + job.ai_verdict + '"'
      + ' class="cursor-pointer">'
      + logVerdictChip(job.ai_verdict, job.rejection_category)
      + '</span></td>'
      + '<td class="py-2.5 px-1 w-0 whitespace-nowrap text-right" style="min-width:2.25rem;">'
      + (job.ai_score != null ? '<span class="text-xs ' + sc + '">' + job.ai_score + '</span>' : '')
      + '</td>'
      + '<td class="pl-2 pr-5 py-2.5 w-0 whitespace-nowrap">'
      + (job.url
          ? '<a href="' + escHtml(job.url) + '" target="_blank" rel="noopener noreferrer" class="text-blue-500 hover:underline text-xs">link</a>'
          : '<span class="text-gray-300 text-xs">\u2014</span>')
      + '</td>'
      + '</tr>';

    mobileRows += '<div class="job-mobile-row px-4 py-3 hover:bg-gray-50 transition-colors' + (target ? ' cursor-pointer' : '') + '"'
      + ' data-row-idx="' + idx + '"'
      + ' data-country="' + escHtml(job.country) + '"'
      + (target ? ' data-href="' + escHtml(target) + '" onclick="location.href=this.dataset.href"' : '')
      + '>'
      + '<div class="flex items-center justify-between gap-2 mb-0.5">'
      + '<span class="text-sm font-medium text-gray-700 truncate">' + escHtml(job.company) + '</span>'
      + '<div class="flex items-center gap-1.5 flex-shrink-0">'
      + '<span onclick="showJobMenu(event,this)"'
      + ' data-internal-id="' + (job.internal_job_id || '') + '"'
      + ' data-url="' + escHtml(job.url || '') + '"'
      + ' data-log-id="' + job.id + '"'
      + ' data-verdict="' + job.ai_verdict + '"'
      + ' class="cursor-pointer">'
      + logVerdictChip(job.ai_verdict, job.rejection_category)
      + '</span>'
      + (job.ai_score != null ? '<span class="text-xs ' + sc + '" style="min-width:1.75rem;display:inline-block;text-align:right;">' + job.ai_score + '</span>' : '')
      + '</div></div>'
      + '<p class="text-xs text-gray-500 truncate">' + escHtml(job.title) + '</p>'
      + (job.location ? '<p class="text-xs text-gray-400 truncate mt-0.5">' + escHtml(job.location) + '</p>' : '')
      + '<p class="text-xs text-gray-300 mt-0.5">' + escHtml(job.logged_date) + ' \u00b7 ' + escHtml(job.logged_time) + '</p>'
      + '</div>';
  });

  return '<table class="hidden md:table w-full"><tbody class="divide-y divide-gray-50">' + tableRows + '</tbody></table>'
       + '<div class="md:hidden jobs-mobile-list divide-y divide-gray-50">' + mobileRows + '</div>';
}

// ---- Lazy-load ----

async function loadRunLogs(runId, detailsEl) {
  const container = detailsEl.querySelector('.run-jobs-container');
  if (!container) return;
  container.innerHTML = '<div class="px-5 py-8 text-center text-sm text-gray-400">Loading\u2026</div>';
  try {
    const res = await fetch('/reports/runs/' + runId + '/logs');
    const data = await res.json();
    container.innerHTML = buildJobsHTML(data.jobs);
    if (isSplitEnabled) applySplitToDetailsEl(detailsEl, true);
  } catch (_) {
    container.innerHTML = '<div class="px-5 py-8 text-center text-sm text-red-400">Failed to load logs.</div>';
  }
}

// Attach toggle listeners to lazy runs
document.querySelectorAll('details[data-run-id]:not([data-preloaded])').forEach(function(details) {
  details.addEventListener('toggle', async function() {
    if (!this.open || this.dataset.loaded) return;
    this.dataset.loaded = '1';
    await loadRunLogs(this.dataset.runId, this);
  });
});

// ---- Location split ----

function buildCountryGroups(rows) {
  const map = new Map();
  rows.forEach(function(row) {
    const c = row.dataset.country || 'Remote / Unknown';
    if (!map.has(c)) map.set(c, []);
    map.get(c).push(row);
  });
  return Array.from(map.entries()).sort(function([a], [b]) {
    if (a === 'Remote / Unknown') return 1;
    if (b === 'Remote / Unknown') return -1;
    return a.localeCompare(b);
  });
}

function applyLocationSplitToTbody(tbody) {
  tbody.querySelectorAll('.country-header').forEach(function(el) { el.remove(); });
  const groups = buildCountryGroups(Array.from(tbody.querySelectorAll('tr[data-row-idx]')));
  groups.forEach(function([country, rows]) {
    const hdr = document.createElement('tr');
    hdr.className = 'country-header';
    hdr.innerHTML = `<td colspan="6" class="px-5 py-2 bg-gray-50 border-y border-gray-100 text-xs font-semibold text-gray-500 uppercase tracking-wide">${escHtml(country)}</td>`;
    tbody.appendChild(hdr);
    rows.forEach(function(r) { tbody.appendChild(r); });
  });
}

function restoreFlatOrderToTbody(tbody) {
  tbody.querySelectorAll('.country-header').forEach(function(el) { el.remove(); });
  const rows = Array.from(tbody.querySelectorAll('tr[data-row-idx]'));
  rows.sort(function(a, b) { return +a.dataset.rowIdx - +b.dataset.rowIdx; });
  rows.forEach(function(r) { tbody.appendChild(r); });
}

function applyLocationSplitToMobileList(list) {
  list.querySelectorAll('.country-header').forEach(function(el) { el.remove(); });
  const groups = buildCountryGroups(Array.from(list.querySelectorAll('[data-row-idx]')));
  groups.forEach(function([country, rows]) {
    const hdr = document.createElement('div');
    hdr.className = 'country-header px-4 py-2 bg-gray-50 border-y border-gray-100 text-xs font-semibold text-gray-500 uppercase tracking-wide';
    hdr.textContent = country;
    list.appendChild(hdr);
    rows.forEach(function(r) { list.appendChild(r); });
  });
}

function restoreFlatOrderToMobileList(list) {
  list.querySelectorAll('.country-header').forEach(function(el) { el.remove(); });
  const rows = Array.from(list.querySelectorAll('[data-row-idx]'));
  rows.sort(function(a, b) { return +a.dataset.rowIdx - +b.dataset.rowIdx; });
  rows.forEach(function(r) { list.appendChild(r); });
}

function applySplitToDetailsEl(detailsEl, split) {
  const tbody = detailsEl.querySelector('tbody');
  const mobileList = detailsEl.querySelector('.jobs-mobile-list');
  if (tbody)      { split ? applyLocationSplitToTbody(tbody)      : restoreFlatOrderToTbody(tbody); }
  if (mobileList) { split ? applyLocationSplitToMobileList(mobileList) : restoreFlatOrderToMobileList(mobileList); }
}

let isSplitEnabled = false;

function toggleLocationSplit(checked) {
  isSplitEnabled = checked;
  document.querySelectorAll('details[data-run-id]').forEach(function(detailsEl) {
    // Only touch runs that are already loaded
    if (detailsEl.hasAttribute('data-preloaded') || detailsEl.dataset.loaded) {
      applySplitToDetailsEl(detailsEl, checked);
    }
  });
  localStorage.setItem('runLogsSplitByLocation', checked ? '1' : '0');
}

// Restore split preference on load
(function() {
  if (localStorage.getItem('runLogsSplitByLocation') === '1') {
    const cb = document.getElementById('location-split-checkbox');
    if (cb) { cb.checked = true; toggleLocationSplit(true); }
  }
})();

// ---- Cost popups ----

function toggleCostPopup(runId) {
  const popup = document.getElementById('cost-popup-' + runId);
  const btn = popup.previousElementSibling;
  const isHidden = popup.classList.contains('hidden');
  document.querySelectorAll('[id^="cost-popup-"]').forEach(function(el) { el.classList.add('hidden'); });
  if (isHidden) {
    const rect = btn.getBoundingClientRect();
    popup.style.top  = (rect.bottom + 4) + 'px';
    popup.style.right = (window.innerWidth - rect.right) + 'px';
    popup.classList.remove('hidden');
  }
}

// ---- Job context menu ----

let _menuTargetEl = null;

function showJobMenu(event, el) {
  event.stopPropagation();
  _menuTargetEl = el;
  const internalId = el.dataset.internalId;
  const url = el.dataset.url;
  const menu = document.getElementById('job-menu');
  const viewLink = document.getElementById('job-menu-view');
  const extLink  = document.getElementById('job-menu-link');

  if (internalId) { viewLink.href = '/job/' + internalId; viewLink.classList.remove('hidden'); }
  else            { viewLink.classList.add('hidden'); }

  if (url) { extLink.href = url; extLink.classList.remove('hidden'); }
  else     { extLink.classList.add('hidden'); }

  document.querySelectorAll('[id^="cost-popup-"]').forEach(function(el) { el.classList.add('hidden'); });
  const rect = el.getBoundingClientRect();
  menu.style.top  = (rect.bottom + 4) + 'px';
  menu.style.left = Math.min(rect.left, window.innerWidth - 172) + 'px';
  menu.classList.remove('hidden');
}

async function menuSetVerdict(newVerdict) {
  const el = _menuTargetEl;
  if (!el) return;
  document.getElementById('job-menu').classList.add('hidden');

  const current = el.dataset.verdict;
  if (newVerdict === current) return;

  const labels = { STRONG_MATCH: 'Strong fit', WEAK_MATCH: 'Weak fit', NO_MATCH: 'No fit' };
  if (!confirm('Change verdict to "' + (labels[newVerdict] || newVerdict) + '"?')) return;

  const internalId = el.dataset.internalId;
  const logId      = el.dataset.logId;
  const endpoint   = internalId
    ? '/api/jobs/' + internalId + '/verdict'
    : '/api/run-log/' + logId + '/verdict';

  try {
    const res  = await fetch(endpoint, { method: 'PATCH', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ verdict: newVerdict }) });
    const data = await res.json();
    if (data.success) {
      el.dataset.verdict = newVerdict;
      if (data.internal_job_id && !internalId) {
        el.dataset.internalId = String(data.internal_job_id);
        document.getElementById('job-menu-view').href = '/job/' + data.internal_job_id;
      }
      el.innerHTML = logVerdictChip(newVerdict, null);
    } else {
      alert(data.error || 'Failed to update verdict');
    }
  } catch (_) {
    alert('Could not reach the server.');
  }
}

document.addEventListener('click', function() {
  document.querySelectorAll('[id^="cost-popup-"]').forEach(function(el) { el.classList.add('hidden'); });
  document.getElementById('job-menu').classList.add('hidden');
});
</script>
